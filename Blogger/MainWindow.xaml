<Window
  x:Class="WinDiskBlogger.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:dd="urn:gong-wpf-dragdrop"
  xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
  xmlns:local="clr-namespace:WinDiskBlogger"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:xp="https://github.com/leoleecs/XamlPearls"
  Name="self"
  Title="{Binding Title}"
  Width="800"
  Height="450"
  WindowState="Maximized"
  mc:Ignorable="d"
>
  <Window.Resources>
    <local:FileIconConverter x:Key="FileIconConverter" />
    <DataTemplate x:Key="CustomDragAdorner">
      <Border
        Padding="10"
        Background="White"
        BorderBrush="LightGray"
        BorderThickness="1"
        CornerRadius="4"
      >
        <Border.Effect>
          <DropShadowEffect BlurRadius="10" Opacity="0.4" ShadowDepth="5" Color="Black" />
        </Border.Effect>

        <StackPanel Orientation="Horizontal">
          <TextBlock FontWeight="Bold" Foreground="#555" Text="Moving: " />
          <TextBlock Foreground="Black" Text="{Binding Name}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>
  <Grid>
    <DockPanel>
      <Menu DockPanel.Dock="Top">
        <MenuItem Header="杂项">
          <MenuItem Header="转换ICO">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="Click">
                <xp:CallMethodAction MethodName="ChoosePngOrSvg" TargetObject="{Binding}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </MenuItem>
          <MenuItem Header="检查ICO图层数量">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="Click">
                <xp:CallMethodAction MethodName="CheckIconFrames" TargetObject="{Binding}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </MenuItem>
        </MenuItem>
      </Menu>

      <ListBox
        Name="lb"
        ItemsSource="{Binding TreeRoots}"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
      >
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid
              Height="{Binding ElementName=lb, Path=ActualHeight}"
              VerticalAlignment="Top"
              Rows="1"
            />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Left" />
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TreeView
              x:Name="FileTreeView"
              Height="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualHeight}"
              HorizontalAlignment="Left"
              dd:DragDrop.DragAdornerTemplate="{StaticResource CustomDragAdorner}"
              dd:DragDrop.DropHandler="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
              dd:DragDrop.IsDragSource="True"
              dd:DragDrop.IsDropTarget="True"
              ItemsSource="{Binding Items}"
            >
              <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                  <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                  <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                  <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
                  <EventSetter
                    Event="RequestBringIntoView"
                    Handler="TreeViewItem_RequestBringIntoView"
                  />
                </Style>
              </TreeView.ItemContainerStyle>

              <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                  <Label>
                    <i:Interaction.Triggers>
                      <i:EventTrigger EventName="MouseDoubleClick">
                        <xp:CallMethodAction
                          MethodName="OpenFile"
                          TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                        >
                          <xp:Parameter Value="{Binding}" />
                        </xp:CallMethodAction>
                      </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <StackPanel Margin="0,2,0,2" Orientation="Horizontal">
                      <Viewbox Width="18" Height="18" Margin="0,0,4,0" VerticalAlignment="Center">
                        <Image>
                          <Image.Source>
                            <MultiBinding Converter="{StaticResource FileIconConverter}">
                              <Binding Path="Name" />
                              <Binding Path="Type" />
                              <Binding Path="IsExpanded" />
                            </MultiBinding>
                          </Image.Source>
                        </Image>
                      </Viewbox>
                      <TextBlock
                        MinWidth="1000"
                        VerticalAlignment="Center"
                        FontFamily="./Assets/#Courier Prime"
                        FontSize="17"
                        Text="{Binding Name, Mode=OneWay}"
                      />
                    </StackPanel>
                  </Label>
                </HierarchicalDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </Grid>
</Window>
